# ─── Database ───────────────────────────────────────────────────────────────
# SQLite local file (the db/ directory is gitignored; created by `bun run db:push`)
DATABASE_URL="file:./db/custom.db"

# ─── AI Provider Configuration ──────────────────────────────────────────────
# DevForge AI works with ANY OpenAI-compatible provider.
# Set these to use a specific provider, or configure via the in-app Settings UI.
#
# AI_API_KEY=your-api-key-here
# AI_BASE_URL=https://api.z.ai/api/paas/v4
#
# Common providers:
#   Z.ai       : https://api.z.ai/api/paas/v4
#   OpenAI     : https://api.openai.com/v1
#   Anthropic  : https://api.anthropic.com/v1
#   Google AI  : https://generativelanguage.googleapis.com/v1
#   Groq       : https://api.groq.com/openai/v1
#   Together AI: https://api.together.xyz/v1
#   Ollama     : http://localhost:11434/v1
