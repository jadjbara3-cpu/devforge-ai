{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DevForge AI",
  "version": "1.0.0",
  "identifier": "com.jadjbara.devforge",
  "build": {
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "DevForge AI",
        "url": "http://localhost:3000",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "maximizable": true,
        "minimizable": true,
        "closable": true,
        "fullscreen": false,
        "center": true,
        "decorations": false,
        "transparent": false,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "focus": true,
        "visible": false,
        "shadow": true,
        "windowEffects": null,
        "backgroundColor": "#0a0a0a",
        "incognito": false,
        "parent": null
      }
    ],
    "security": {
      "csp": null,
      "devCsp": null,
      "freezePrototype": false,
      "dangerousDisableAssetCspModification": false,
      "assetProtocol": {
        "enable": false,
        "scope": []
      }
    },
    "trayIcon": {
      "id": "main-tray",
      "iconPath": "icons/tray-icon.png",
      "iconAsTemplate": false,
      "menuOnLeftClick": false,
      "title": "DevForge AI",
      "tooltip": "DevForge AI"
    },
    "macOSPrivateApi": false
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [],
    "copyright": "© 2026 Jad Jbara",
    "category": "DeveloperTool",
    "shortDescription": "DevForge AI — Native desktop shell",
    "longDescription": "DevForge AI is an integrated full-stack AI developer hub combining LLM chat, vision, image generation, voice, web intelligence and a real-time task board — wrapped in a native Windows desktop shell.",
    "publisher": "Jad Jbara",
    "homepage": "https://github.com/jadjbara3-cpu/devforge-ai",
    "appimage": {
      "bundleMediaFramework": false
    },
    "iOS": {},
    "linux": {
      "deb": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": false
      },
      "rpm": {
        "depends": []
      }
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "languages": ["English"],
        "template": null,
        "headerImage": null,
        "sidebarImage": null,
        "installerIcon": "icons/icon.ico",
        "installHooks": null,
        "compression": "lzma2",
        "startMenuFolder": "DevForge AI",
        "installerHooks": null
      },
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "wix": null,
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.sectigo.com",
      "tsp": false,
      "allowDowngrades": false
    }
  },
  "plugins": {
    "single-instance": {
      "deepLink": {
        "enabled": false
      }
    },
    "window-state": {
      "restorePrevState": true
    },
    "autostart": {
      "macosExtraArgs": [],
      "linuxExtraArgs": []
    }
  }
}
